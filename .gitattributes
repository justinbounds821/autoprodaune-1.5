# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# PowerShell scripts should use CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# Shell scripts and source code should use LF
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
