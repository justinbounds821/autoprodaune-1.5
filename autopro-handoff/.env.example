# ============================================================================
# AutoPro Daune – Consolidated Environment Configuration
# ============================================================================
# Copy this to `.env` in root and configure with your values
# Separate .env files for backend (services/api/.env) and frontend (02_FRONTEND_UI_CLEAN/.env)
# can override these defaults

# ============================================================================
# BACKEND – FastAPI + Uvicorn
# ============================================================================

# Server Configuration
PORT=8001
HOST=127.0.0.1
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# CORS Origins (CRITICAL: must include FE ports!)
# Add :3006 and :3007 for local dev
BACKEND_CORS_ORIGINS=http://localhost:3006,http://127.0.0.1:3006,http://localhost:3007,http://127.0.0.1:3007,http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=dev-secret-key-32-chars-minimum-change-in-prod
JWT_SECRET_KEY=dev-jwt-secret-key-here-change-in-prod
ADMIN_PASSWORD=admin123

# ============================================================================
# FRONTEND – Vite + React
# ============================================================================

# API Configuration
VITE_API_URL=http://127.0.0.1:8001
VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=20000

# Environment
VITE_ENV=development
VITE_ENABLE_METRICS=true

# Auth Mode (bearer token in Authorization header)
VITE_AUTH_MODE=bearer

# ============================================================================
# DATABASE – Supabase
# ============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# REDIS – Rate Limiting & Caching
# ============================================================================

# Set to "disabled" for in-memory fallback in dev
# In production: redis://localhost:6379 or redis://user:pass@host:port/db
REDIS_URL=disabled
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_MODE=memory
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60

# ============================================================================
# AI / VIDEO PROVIDERS
# ============================================================================

# HeyGen (AI Avatar Video Generation)
# Leave empty to disable HeyGen features (UX will show banner instead of error)
HEYGEN_API_KEY=

# Pika (Alternative Video Provider)
VEO_PROVIDER=Pika
VEO_API_KEY=
VEO_MODEL=
VEO_MAX_SECONDS=10

# ============================================================================
# CLOUD STORAGE – Cloudflare R2 (S3 compatible)
# ============================================================================

R2_ENDPOINT=
R2_BUCKET=apd-uploads
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_BASE_URL=
R2_REGION=
R2_MIME_WHITELIST=image/jpeg,image/png,application/pdf
R2_RETENTION_DAYS=365

# ============================================================================
# GOOGLE SHEETS INTEGRATION
# ============================================================================

GSPREAD_SERVICE_ACCOUNT_FILE=credentials.json
GOOGLE_SHEET_LEADS_ID=
GOOGLE_SHEET_REFERRALS_ID=
GOOGLE_SHEET_KPI_ID=

# ============================================================================
# TELEGRAM BOT
# ============================================================================

BOT_TOKEN=
BOT_USERNAME=
ADMIN_CHAT_ID=
GROUP_ID=

# ============================================================================
# SOCIAL MEDIA – Autoposter
# ============================================================================

# Autoposter Configuration
AUTOPOSTER_DIRECTORY=./videos/to_publish
AUTOPOSTER_RATIO=tiktok:0.4,instagram:0.4,youtube:0.2

# TikTok API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_USER_ID=

# Instagram Graph API
IG_BUSINESS_ACCOUNT_ID=
IG_LONG_LIVED_TOKEN=
IG_CROSSPOST_TO_FB=false
IG_PAGE_ID=

# YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY_STATUS=public

# Publer Fallback API
PUBLER_API_KEY=
PUBLER_PROFILE_IDS=
PUBLER_TIMEZONE=Europe/Bucharest

# ============================================================================
# N8N WORKFLOWS (Self-hosted automation)
# ============================================================================

N8N_BASE_URL=https://flows.autopro-daune.ro
N8N_LEAD_INTAKE=https://flows.autopro-daune.ro/webhook/lead-intake
N8N_REFERRAL_IN=https://flows.autopro-daune.ro/webhook/referral-in
N8N_STATUS_QUERY=https://flows.autopro-daune.ro/webhook/status-query
N8N_OPERATOR_TAKE=https://flows.autopro-daune.ro/webhook/operator-take
N8N_REFERRAL_DONE=https://flows.autopro-daune.ro/webhook/referral-done

# ============================================================================
# ANALYTICS & SEO
# ============================================================================

PLAUSIBLE_ENABLED=true
PLAUSIBLE_DOMAIN=autopro-daune.ro
TIKTOK_PIXEL_ID=
META_PIXEL_ID=

# ============================================================================
# SMTP / EMAIL NOTIFICATIONS
# ============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ============================================================================
# MISC
# ============================================================================

BASE_URL=https://autopro-daune.ro
TIMEZONE=Europe/Bucharest

# ============================================================================
# NOTES
# ============================================================================
# 1. CORS: Ensure BACKEND_CORS_ORIGINS includes all FE ports (3006, 3007, etc.)
# 2. HeyGen: If HEYGEN_API_KEY is empty, FE will show banner instead of error
# 3. Redis: Set REDIS_URL=disabled for in-memory fallback in dev (no warnings)
# 4. Supabase: Run sql/automation_config.sql in Supabase SQL Editor if needed
# 5. Security: Change SECRET_KEY, JWT_SECRET_KEY, ADMIN_PASSWORD in production!
