ue Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/mcp/tools/github/commit":{"post":{"summary":"Mcp Github Commit","description":"Create Git commit via orchestrator","operationId":"mcp_github_commit_mcp_tools_github_commit_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GitHubCommitRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Mcp Github Commit Mcp Tools Github Commit Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/mcp/tools/supabase/query":{"post":{"summary":"Mcp Supabase Query","description":"Execute Supabase query via orchestrator","operationId":"mcp_supabase_query_mcp_tools_supabase_query_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SupabaseQueryRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Mcp Supabase Query Mcp Tools Supabase Query Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/mcp/tools/supabase/verify":{"post":{"summary":"Mcp Supabase Verify","description":"Verify database fix via orchestrator","operationId":"mcp_supabase_verify_mcp_tools_supabase_verify_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SupabaseVerifyRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Mcp Supabase Verify Mcp Tools Supabase Verify Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema