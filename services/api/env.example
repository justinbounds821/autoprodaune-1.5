# AutoPro Daune - Backend Environment Template
# Copy this to .env and fill in your actual values

# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8001
HOST=127.0.0.1
BACKEND_CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003,http://localhost:3000,http://127.0.0.1:3000

# ============================================
# SOCIAL MEDIA API KEYS
# ============================================
TIKTOK_API_KEY=your_tiktok_api_key
TIKTOK_API_SECRET=your_tiktok_api_secret
INSTAGRAM_API_KEY=your_instagram_api_key
INSTAGRAM_API_SECRET=your_instagram_api_secret
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_API_SECRET=your_youtube_api_secret

# ============================================
# HEYGEN VIDEO GENERATION
# ============================================
HEYGEN_API_KEY=your_heygen_api_key
HEYGEN_API_URL=https://api.heygen.com

# ============================================
# INTERNAL VIDEO ENGINE
# ============================================
# Activează engine-ul nostru intern (true/false)
USE_INTERNAL_VIDEO_ENGINE=true

# Alege backendul de lip-sync (sadtalker/wav2lip)
LIPSYNC_BACKEND=sadtalker

# TTS Configuration (ElevenLabs sau fallback local)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=Rachel

# Video Quality Settings
VIDEO_ENGINE_FPS=25
VIDEO_ENGINE_CANVAS=1280x720

# Background Image (opțional)
VIDEO_ENGINE_BG_IMAGE=services/api/assets/bg.jpg

# ============================================
# WHATSAPP BUSINESS API
# ============================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ============================================
# EMAIL & SMS SERVICES
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ============================================
# MONITORING & LOGGING
# ============================================
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your_secret_key_here_32_chars_minimum
JWT_SECRET_KEY=your_jwt_secret_key_here
ADMIN_PASSWORD=your_admin_password_here

# ============================================
# FILE STORAGE
# ============================================
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET_NAME=your_bucket_name
CLOUDFLARE_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ============================================
# PHASE 8/9: AI ENHANCEMENTS & VIDEO ENGINE
# ============================================

# AI Feature Toggles (safe-by-default: disabled unless explicitly enabled)
ENABLE_AI_INSIGHTS=false
ENABLE_WHISPER_CAPTIONS=false
ENABLE_SCENE_DETECT=false
ENABLE_TAGGING=false
ENABLE_VECTOR_SEARCH=false
ENABLE_BROLL_INJECT=false
ENABLE_AUDIO_ENHANCE=false
ENABLE_COST_TRACKER=false
ENABLE_CDN_CACHE=false
ENABLE_WEBHOOKS=false

# Whisper Configuration (auto-captions)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
AI_CAPTIONS_LANG=ro

# Vector Search (semantic video search)
AI_PGVECTOR_DIM=384
VECTOR_SIMILARITY_THRESHOLD=0.7

# Audio Enhancement
AUDIO_TARGET_LUFS=-16
AUDIO_NOISE_GATE_DB=-45

# Scene Detection
SCENE_DETECT_THRESHOLD=30.0

# B-roll Injection
BROLL_LIBRARY_PATH=assets/broll
BROLL_INJECT_FREQUENCY=30

# Cost Tracking (per-unit costs in dollars)
TTS_COST_PER_SECOND=0.01
PROCESSING_COST_PER_SECOND=0.001
STORAGE_COST_PER_MB=0.0001
AI_EMBEDDING_COST=0.0001
AI_CAPTION_COST=0.05

# Housekeeping (auto-cleanup)
TTL_COMPLETED_DAYS=30
TTL_FAILED_DAYS=7
CLEANUP_INTERVAL_MINUTES=60

# CDN Configuration
CDN_PROVIDER=cloudflare_r2
CDN_DOMAIN=
CDN_ZONE_ID=
CDN_API_TOKEN=
CDN_URL_SIGNING_SECRET=
CDN_DEFAULT_TTL=3600

# Webhook Notifications
WEBHOOK_COMPLETED_URL=
WEBHOOK_FAILED_URL=
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT=30

# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=false
