{
  "name": "mcp-orchestrator",
  "version": "1.0.0",
  "description": "MCP Orchestrator HTTP Bridge",
  "type": "module",
  "main": "dist/http-bridge.js",
  "scripts": {
    "build": "tsc src/http-bridge.ts --outDir dist --module ES2022 --target ES2022 --lib ES2022 --esModuleInterop --skipLibCheck --resolveJsonModule --moduleResolution node",
    "start": "node dist/http-bridge.js",
    "dev": "npm run build && npm run start"
  },
  "dependencies": {
    "@linear/sdk": "^24.0.0",
    "@octokit/rest": "^20.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "playwright": "^1.40.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3"
  }
}

