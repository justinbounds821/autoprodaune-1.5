# AutoPro Daune - Environment Configuration Template
# COPIAZĂ ACEST FIȘIER CA .env ȘI COMPLETEAZĂ CU VALORILE REALE

# Base Configuration
BASE_URL=https://autopro-daune.ro
LOG_LEVEL=INFO
ADMIN_PASSWORD=your_secure_admin_password_here

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=AUTOPRODAUNE_BOT
ADMIN_CHAT_ID=your_admin_chat_id
GROUP_ID=your_group_id

# Cloudflare R2 Storage
R2_ENDPOINT=your_cloudflare_r2_endpoint
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=autopro-daune
R2_PUBLIC_BASE_URL=your_r2_public_url

# Google Sheets
GOOGLE_SHEET_LEADS_ID=your_google_sheet_leads_id
GOOGLE_SHEET_REFERRALS_ID=your_google_sheet_referrals_id
GSPREAD_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json

# n8n Webhooks
N8N_BASE_URL=http://localhost:5678
N8N_LEAD_INTAKE=http://localhost:5678/webhook/lead-intake
N8N_REFERRAL_IN=http://localhost:5678/webhook/referral-in
N8N_STATUS_QUERY=http://localhost:5678/webhook/status-query
N8N_OPERATOR_TAKE=http://localhost:5678/webhook/operator-take
