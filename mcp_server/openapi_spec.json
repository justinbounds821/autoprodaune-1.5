 Response","content":{"application/json":{"schema":{"type":"object","title":"Response Gpt Run Test Mcp Tools Gpt Test Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}},"tags":["GPT Developer Mode"]}},"/mcp/tools/gpt/status":{"get":{"summary":"Gpt System Status","description":"GPT Developer Mode: Get comprehensive system status\nIncludes orchestrator, backend, database, etc.\n\n**GPT Note**: This endpoint returns GPT-optimized responses.","operationId":"gpt_system_status_mcp_tools_gpt_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Gpt System Status Mcp Tools Gpt Status Get"}}}}},"tags":["GPT Developer Mode"]}}},"components":{"schemas":{"APITestRequest":{"properties":{"method":{"type":"string","pattern":"^(GET|POST|PUT|DELETE|PATCH)$","title":"Method"},"url":{"type":"string","title":"Url"},"body":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Body"},"headers":{"anyOf":[{"additionalProperties":{"type":"string"},"type":"object"},{"type":"null"}],"title":"Headers"},"expected_status":{"type":"integer","title":"Expected Status","default":200},"expected_response":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Expected Response"}},"type":"object","required":["method","url"],"title":"APITestRequest"},"BrowserTestRequest":{"properties":{"test_name":{"type":"string","title":"Test Name"},"url":{"type":"string","title":"Url"},"steps":{"items":{"type":"object"},"type":"array","title":"Steps"},"verify_in_db":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Verify In Db"}},"type":"object","required":["test_name","url","steps"],"title":"BrowserTestRequest"},"ExecuteRequest":{"properties":{"task":{"type":"string","title":"Task"},"context":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Context"}},"type":"object","required":["task"],"title":"ExecuteRequest"},"ExecuteRespon