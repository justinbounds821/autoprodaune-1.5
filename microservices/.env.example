# AutoPro Microservices Environment Variables

# ==================== DATABASE ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/autopro

# ==================== CACHE & QUEUE ====================
REDIS_URL=redis://:redis_password@redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ==================== EXTERNAL APIS ====================
# Social Media
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# Notifications
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_NUMBER=

# AI/ML
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=

# MCP Integrations
LINEAR_API_KEY=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_KEY=

# ==================== SERVICE CONFIG ====================
LOG_LEVEL=INFO
CORS_ORIGINS=*
ENVIRONMENT=production

# ==================== MONITORING ====================
SENTRY_DSN=
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
