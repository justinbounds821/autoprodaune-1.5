# ===================================================
# AutoPro Daune - Complete Production Environment Configuration
# ===================================================

# ==================== APPLICATION ====================
PROJECT_NAME="AutoPro Daune"
DEBUG=false
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production

# Public base URL of your application
BASE_URL=https://autopro-daune.ro
TIMEZONE=Europe/Bucharest
LOG_LEVEL=info

# ==================== DATABASE (SUPABASE) ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ==================== WHATSAPP BUSINESS API ====================
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_BASE=https://graph.facebook.com/v18.0
MANOLE_PHONE=+40723456789

# ==================== SOCIAL MEDIA APIS ====================
# TikTok API credentials
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_USER_ID=your-tiktok-user-id

# Instagram Graph API
IG_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id
IG_LONG_LIVED_TOKEN=your-instagram-long-lived-token
IG_CROSSPOST_TO_FB=false
IG_PAGE_ID=your-facebook-page-id

# YouTube Data API
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token
YOUTUBE_CHANNEL_ID=your-youtube-channel-id
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY_STATUS=public

# Facebook/Instagram additional
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# ==================== VIDEO GENERATION ====================
# AI video providers
VEO_PROVIDER=Pika
VEO_API_KEY=your-pika-api-key
VEO_MODEL=pika-v2-1
VEO_MAX_SECONDS=60
HEYGEN_API_KEY=your-heygen-api-key

# Pika Labs API
PIKA_API_KEY=your-pika-api-key
PIKA_BASE_URL=https://api.pikalabs.ai

# HeyGen API
HEYGEN_BASE_URL=https://api.heygen.com

# OpenAI for content generation
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# ==================== STORAGE (CLOUDFLARE R2) ====================
# Cloudflare R2 S3 storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=autoprodaune-storage
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_PUBLIC_BASE_URL=https://cdn.autoprodaune.com
R2_REGION=auto
R2_MIME_WHITELIST=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/mov,application/pdf,text/plain
R2_RETENTION_DAYS=365

# Alternative AWS-style configuration (same as R2)
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key
AWS_REGION=auto
CLOUDFLARE_R2_BUCKET=autoprodaune-storage
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.autoprodaune.com

# ==================== REFERRAL SYSTEM ====================
REFERRAL_REWARD_AMOUNT=200.0
REFERRAL_CURRENCY=LEI
MINIMUM_PAYOUT=200.0
REFERRAL_CODE_LENGTH=8

# ==================== AUTOMATION SCHEDULE ====================
DAILY_VIDEO_COUNT=3
POSTING_SCHEDULE=09:00,15:00,21:00
AUTOMATION_TIMEZONE=Europe/Bucharest
AUTOMATION_ENABLED=true

# Content template weights (should add up to 100)
EDUCATIONAL_WEIGHT=40
TESTIMONIAL_WEIGHT=30
PROMOTIONAL_WEIGHT=30

# Autoposter settings
AUTOPOSTER_DIRECTORY=./videos/to_publish
AUTOPOSTER_RATIO=tiktok:0.4,instagram:0.4,youtube:0.2

# ==================== SECURITY ====================
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_VIDEO_REQUESTS=5
RATE_LIMIT_VIDEO_WINDOW=300

# ==================== CORS SETTINGS ====================
ALLOWED_ORIGINS=https://autopro-daune.ro,https://www.autopro-daune.ro,https://app.autopro-daune.ro

# ==================== REDIS ====================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# ==================== N8N WORKFLOWS (LEGACY) ====================
N8N_BASE_URL=https://flows.autopro-daune.ro
N8N_LEAD_INTAKE=https://flows.autopro-daune.ro/webhook/lead-intake
N8N_REFERRAL_IN=https://flows.autopro-daune.ro/webhook/referral-in
N8N_STATUS_QUERY=https://flows.autopro-daune.ro/webhook/status-query
N8N_OPERATOR_TAKE=https://flows.autopro-daune.ro/webhook/operator-take
N8N_REFERRAL_DONE=https://flows.autopro-daune.ro/webhook/referral-done

# ==================== EMAIL SETTINGS ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@autoprodaune.com

# ==================== GOOGLE SHEETS (LEGACY) ====================
GSPREAD_SERVICE_ACCOUNT_FILE=credentials.json
GOOGLE_SHEET_LEADS_ID=your-google-sheet-id
GOOGLE_SHEET_REFERRALS_ID=your-google-sheet-referrals-id
GOOGLE_SHEET_KPI_ID=your-google-sheet-kpi-id

# ==================== TELEGRAM BOT (LEGACY) ====================
BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=autoprodaunebot
ADMIN_CHAT_ID=your-admin-chat-id
GROUP_ID=your-telegram-group-id

# ==================== PUBLER FALLBACK API ====================
PUBLER_API_KEY=your-publer-api-key
PUBLER_PROFILE_IDS=your-publer-profile-ids
PUBLER_TIMEZONE=Europe/Bucharest

# ==================== MONITORING & ANALYTICS ====================
# Sentry for error tracking
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Google Analytics / Plausible
PLAUSIBLE_ENABLED=true
PLAUSIBLE_DOMAIN=autopro-daune.ro
ANALYTICS_GA_ID=your-google-analytics-id

# Social Media Pixels
TIKTOK_PIXEL_ID=your-tiktok-pixel-id
META_PIXEL_ID=your-meta-pixel-id

# Prometheus monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# ==================== BUSINESS SETTINGS ====================
COMPANY_NAME="AutoPro Daune"
COMPANY_PHONE="+40 723 456 789"
COMPANY_EMAIL="contact@autoprodaune.com"
COMPANY_ADDRESS="București, România"
SUPPORT_EMAIL="support@autoprodaune.com"

# Working hours
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=Europe/Bucharest

# ==================== FEATURE FLAGS ====================
ENABLE_VIDEO_GENERATION=true
ENABLE_AUTO_POSTING=true
ENABLE_WHATSAPP_BOT=true
ENABLE_REFERRAL_SYSTEM=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_CACHING=true

# Debug features (should be false in production)
ENABLE_DEBUG_ROUTES=false
ENABLE_MOCK_SOCIAL_APIS=false
ENABLE_TEST_WEBHOOKS=false

# ==================== PERFORMANCE SETTINGS ====================
# Worker settings
UVICORN_WORKERS=4
WORKER_CONNECTIONS=1000

# Background task settings
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKERS=4

# ==================== DOCKER SETTINGS ====================
COMPOSE_PROJECT_NAME=autoprodaune
DOCKER_REGISTRY=registry.autoprodaune.com
DOCKER_IMAGE_TAG=latest

# Health check intervals
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3