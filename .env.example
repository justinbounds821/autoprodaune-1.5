# Example environment configuration for AutoPro Daune
#
# Copy this file to `.env` and fill in the values for your deployment.
# Lines beginning with `#` are comments and explain the purpose of each variable.

# -----------------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------------
# The public base URL of your Streamlit application.  Used to build links.
BASE_URL=https://autopro-daune.ro
# Time zone for scheduling tasks and displaying dates
TIMEZONE=Europe/Bucharest
# Logging level: one of debug, info, warning, error
LOG_LEVEL=info
# Enable FAKE_MODE for testing without real database/API connections (true/false)
FAKE_MODE=false

# -----------------------------------------------------------------------------
# Streamlit configuration
# -----------------------------------------------------------------------------
# Port where the Streamlit app will run (default 8501).  You can override
# this when running the app with `streamlit run`.
PORT=8501

# -----------------------------------------------------------------------------
# n8n webhooks (self‑hosted instance)
# -----------------------------------------------------------------------------
# Base URL for your n8n instance
N8N_BASE_URL=https://flows.autopro-daune.ro
# Full webhook URLs for each workflow (these must match the n8n configuration)
N8N_LEAD_INTAKE=https://flows.autopro-daune.ro/webhook/lead-intake
N8N_REFERRAL_IN=https://flows.autopro-daune.ro/webhook/referral-in
N8N_STATUS_QUERY=https://flows.autopro-daune.ro/webhook/status-query
N8N_OPERATOR_TAKE=https://flows.autopro-daune.ro/webhook/operator-take
N8N_REFERRAL_DONE=https://flows.autopro-daune.ro/webhook/referral-done

# -----------------------------------------------------------------------------
# AI video providers
# -----------------------------------------------------------------------------
# Provider to use for generating videos.  Options: Pika (recommended), HeyGen.
VEO_PROVIDER=Pika
# API key for the primary provider (Pika or HeyGen depending on VEO_PROVIDER)
VEO_API_KEY=
# Model/version to use (optional).  For Pika this could be pika-v2-1.
VEO_MODEL=
# Maximum length in seconds for generated videos (default 10).  Clips
# longer than this may be truncated by the provider.
VEO_MAX_SECONDS=10
# API key for HeyGen when VEO_PROVIDER=HeyGen (optional fallback)
HEYGEN_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 S3 storage
# -----------------------------------------------------------------------------
# Endpoint for your R2 S3 compatible storage
R2_ENDPOINT=
# Name of the bucket to store uploads
R2_BUCKET=apd-uploads
# Access key ID for R2
R2_ACCESS_KEY=
# Secret key for R2
R2_SECRET_KEY=
# Public base URL used to construct file URLs (e.g. https://cdn.example.com)
R2_PUBLIC_BASE_URL=
# Region string; leave empty for automatic detection
R2_REGION=
# Comma‑separated list of allowed MIME types for uploads
R2_MIME_WHITELIST=image/jpeg,image/png,application/pdf
# Retention period for uploads in days
R2_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
# Path to the service account JSON file used for Google Sheets API
GSPREAD_SERVICE_ACCOUNT_FILE=credentials.json
# ID of the sheet where lead submissions will be appended
GOOGLE_SHEET_LEADS_ID=
# ID of the sheet where referrals will be appended
GOOGLE_SHEET_REFERRALS_ID=
# ID of the sheet used for KPI/analytics (optional)
GOOGLE_SHEET_KPI_ID=

# -----------------------------------------------------------------------------
# Telegram bot settings
# -----------------------------------------------------------------------------
# Bot token obtained from BotFather
BOT_TOKEN=
# Bot username (without @).  Used to build deep links for referrals.
BOT_USERNAME=
# Telegram chat ID of the admin/owner to receive notifications
ADMIN_CHAT_ID=
# ID of the Telegram group where new users will be invited to join
GROUP_ID=

# -----------------------------------------------------------------------------
# Autoposter
# -----------------------------------------------------------------------------
# Directory where videos ready for publishing are stored.  Each video should
# have a companion JSON file with the same basename containing at least a
# "caption" field.
AUTOPOSTER_DIRECTORY=./videos/to_publish
# Platform distribution ratio for autoposter (comma‑separated platform:ratio).
# Default is TikTok 40%, Instagram 40%, YouTube 20%.  Values must sum to 1.
AUTOPOSTER_RATIO=tiktok:0.4,instagram:0.4,youtube:0.2

# -----------------------------------------------------------------------------
# TikTok API credentials
# -----------------------------------------------------------------------------
# Client key and secret obtained from TikTok developer portal
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# OAuth access token with `upload.video` scope
TIKTOK_ACCESS_TOKEN=
# Open ID or user ID of the TikTok account where videos will be posted
TIKTOK_USER_ID=

# -----------------------------------------------------------------------------
# Instagram Graph API
# -----------------------------------------------------------------------------
# Business account ID for Instagram
IG_BUSINESS_ACCOUNT_ID=
# Long‑lived access token with instagram_content_publish permission
IG_LONG_LIVED_TOKEN=
# Whether to cross‑post Instagram videos to Facebook (true/false)
IG_CROSSPOST_TO_FB=false
# Facebook Page ID used when cross‑posting (optional)
IG_PAGE_ID=

# -----------------------------------------------------------------------------
# YouTube Data API
# -----------------------------------------------------------------------------
# OAuth2 client ID and secret for YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Refresh token for the account authorised to upload videos
YOUTUBE_REFRESH_TOKEN=
# ID of the channel where videos will be uploaded
YOUTUBE_CHANNEL_ID=
# Category ID for videos (default 22: People & Blogs)
YOUTUBE_CATEGORY_ID=22
# Privacy status for new videos (public, unlisted, or private)
YOUTUBE_PRIVACY_STATUS=public

# -----------------------------------------------------------------------------
# Publer fallback API
# -----------------------------------------------------------------------------
# API key for Publer
PUBLER_API_KEY=
# Comma‑separated list of profile IDs in Publer.  If omitted, posts will
# publish to all profiles linked to the account.
PUBLER_PROFILE_IDS=
# Time zone used by Publer for scheduling (e.g. Europe/Bucharest)
PUBLER_TIMEZONE=Europe/Bucharest

# -----------------------------------------------------------------------------
# Analytics and SEO
# -----------------------------------------------------------------------------
# Whether to enable Plausible analytics (true/false)
PLAUSIBLE_ENABLED=true
# Domain configured in Plausible
PLAUSIBLE_DOMAIN=autopro-daune.ro
# TikTok Pixel ID (optional).  Injected into SEO header when set.
TIKTOK_PIXEL_ID=
# Meta Pixel/Facebook Pixel ID (optional)
META_PIXEL_ID=

# -----------------------------------------------------------------------------
# SMTP settings (optional; used for sending emails/alerts)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Email address from which notifications are sent
SMTP_FROM=